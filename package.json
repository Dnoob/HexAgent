{
  "name": "HexAgent",
  "version": "0.2.0",
  "description": "AI desktop assistant with multi-LLM support, tool execution and file operations",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder"
  },
  "keywords": [],
  "author": "Dnoob",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dnoob/HexAgent"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.hexagent.app",
    "productName": "HexAgent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "antd": "^6.2.3",
    "better-sqlite3": "^12.6.2",
    "highlight.js": "^11.11.1",
    "openai": "^6.18.0",
    "puppeteer-core": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
